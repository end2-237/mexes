# ============================================================
# Clé Minutes — Variables d'environnement (Next.js + Supabase)
# Copiez ce fichier en .env.local et remplissez les valeurs.
# ============================================================

# ── Base de données Supabase (PostgreSQL) ──────────────────
# Récupérez la chaîne dans : Supabase > Project Settings > Database > Connection string (URI)
# Utilisez le pooler (port 6543) pour les fonctions serverless Vercel.
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# ── Client Supabase (optionnel, pour auth/storage Supabase) ─
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Sécurité JWT (port de app/core/security.py) ────────────
# Générez : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRET_KEY=changez-en-production
TOKEN_EXPIRE_HOURS=24

# ── Chatbot IA (Anthropic / Claude) ────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── WhatsApp Cloud API (notifications) ─────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# ── URLs publiques ─────────────────────────────────────────
APP_WEB_URL=https://app.cleminutes.cm

# ── Multi-hosting (middleware.ts) ──────────────────────────
NEXT_PUBLIC_ROOT_DOMAIN=cleminutes.cm
NEXT_PUBLIC_DASHBOARD_HOST=app.cleminutes.cm
